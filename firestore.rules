rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /customers/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;

      match /vehicles/{vehicleId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // PIN routing reads happen before Firebase Auth (smartRoute). 
    match /phone_index/{phoneKey} {
      allow read: if true;
      // Allow creation only if the UID matches the auth UID and document doesn't exist
      allow create: if request.auth != null 
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/phone_index/$(phoneKey));
      // Allow update only if the UID matches the existing UID
      allow update: if request.auth != null 
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // Public wash logs for audit (read-only for authenticated users)
    match /wash_logs/{logId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null; // Typically created via batch/SDK
    }
  }
}
